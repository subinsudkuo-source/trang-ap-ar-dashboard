  sheet.getRange(1, 1, 1, headers.length).setBackground('#175466').setFontColor('#ffffff').setFontWeight('bold');
}

function isMay2569_(display, raw) {
  const text = String(display || '').trim();
  if (text === 'พฤษภาคม 2569' || text === '2569-05-01T07:00:00.000Z') return true;
  if (/^1[\/\-]5[\/\-]2569$/.test(text)) return true;
  if (raw instanceof Date) return raw.getFullYear() === 2026 && raw.getMonth() === 4;
  const parsed = new Date(String(raw || ''));
  return !isNaN(parsed.getTime()) && parsed.getFullYear() === 2026 && parsed.getMonth() === 4;
}
